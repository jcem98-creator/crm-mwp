#
# Variables que usa el proyecto (ver `src/config.ts`)
#

# --- LLM (requerida) ---
OPENAI_API_KEY="TU_OPENAI_API_KEY"

# --- Evolution API (requeridas) ---
EVOLUTION_API_URL="https://TU_DOMINIO_O_IP_DE_EVOLUTION"
EVOLUTION_INSTANCE_NAME="NOMBRE_DE_LA_INSTANCIA"
EVOLUTION_API_KEY="TU_EVOLUTION_API_KEY"

# --- Servidor ---
PORT="3000"

# --- Seguridad webhook (opcional, recomendado) ---
# Si lo defines, debes enviar el header `x-webhook-secret` o `?token=...` en el webhook.
WEBHOOK_SECRET="CAMBIA_ESTO"

# --- Base de datos (SQLite) ---
DB_PATH="./memory.db"

# --- Variables opcionales (no usadas por el runtime actual, se dejan como referencia) ---
# TELEGRAM_BOT_TOKEN="TU_TOKEN_DE_TELEGRAM_AQUI"
# TELEGRAM_ALLOWED_USER_IDS="123456789,987654321"
# GROQ_API_KEY="TU_API_KEY_DE_GROQ"
# OPENROUTER_API_KEY="TU_API_KEY_DE_OPENROUTER"
# OPENROUTER_MODEL="openrouter/free"
# GOOGLE_APPLICATION_CREDENTIALS="./service-account.json"
